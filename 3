<!DOCTYPE html>
<html>
<head>
    <title>Registration & Login</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
        }
        form {
            border: 2px solid black;
            padding: 20px;
            width: 300px;
            margin: 20px auto;
        }
        input {
            margin: 10px;
            padding: 8px;
            width: 80%;
        }
        button {
            padding: 10px;
            width: 90%;
        }
    </style>
</head>
<body>

<h2>Registration Form</h2>

<form id="registerForm">
    <input type="text" id="regUser" placeholder="Enter Username"><br>
    <input type="email" id="regEmail" placeholder="Enter Email"><br>
    <input type="password" id="regPass" placeholder="Enter Password"><br>
    <button type="submit">Register</button>
</form>

<h2 style="display:none;" id="loginTitle">Login Form</h2>

<form id="loginForm" style="display:none;">
    <input type="text" id="loginUser" placeholder="Enter Username"><br>
    <input type="password" id="loginPass" placeholder="Enter Password"><br>
    <button type="submit">Login</button>
</form>

<p id="message"></p>

<script>
    const regForm = document.getElementById("registerForm");
    const loginForm = document.getElementById("loginForm");

    regForm.addEventListener("submit", function(e) {
        e.preventDefault();

        let user = document.getElementById("regUser").value;
        let email = document.getElementById("regEmail").value;
        let pass = document.getElementById("regPass").value;

        // Validation
        if(user === "" || email === "" || pass === "") {
            alert("All fields are required!");
            return;
        }

        if(pass.length < 6) {
            alert("Password must be at least 6 characters!");
            return;
        }

        // Store data
        localStorage.setItem("username", user);
        localStorage.setItem("password", pass);

        alert("Registration Successful!");

        // Show login form
        regForm.style.display = "none";
        document.getElementById("loginTitle").style.display = "block";
        loginForm.style.display = "block";
    });

    loginForm.addEventListener("submit", function(e) {
        e.preventDefault();

        let loginUser = document.getElementById("loginUser").value;
        let loginPass = document.getElementById("loginPass").value;

        let storedUser = localStorage.getItem("username");
        let storedPass = localStorage.getItem("password");

        if(loginUser === storedUser && loginPass === storedPass) {
            document.getElementById("message").innerHTML = "Login Successful!";
        } else {
            document.getElementById("message").innerHTML = "Invalid Credentials!";
        }
    });
</script>

</body>
</html>
